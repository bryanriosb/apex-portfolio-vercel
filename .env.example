# Authentication
JWT_SECRET=your-jwt-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Environment
ENVIRONMENT=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_PUBLIC_KEY=your-supabase-public-key

# Public Supabase Configuration (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-whatsapp-verify-token

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
SQS_BATCH_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/your-queue.fifo

# Lambda Worker ARN
LAMBDA_EMAIL_WORKER_ARN=arn:aws:lambda:us-east-1:your-account-id:function:your-function-name

# Mercado Pago Configuration
# Access Token - Server side only (use TEST- prefix for sandbox)
MP_ACCESS_TOKEN_TEST=your-mp-access-token-test
MP_ACCESS_TOKEN=your-mp-access-token

# Public Key - Client side (exposed to browser, use TEST- prefix for sandbox)
NEXT_PUBLIC_MP_PUBLIC_KEY=your-mp-public-key

# Webhook secret (optional, for signature verification)
MP_WEBHOOK_SECRET=your-mp-webhook-secret

# Sandbox mode flag (true = test, false = production)
MP_SANDBOX=false
NEXT_PUBLIC_MP_SANDBOX=false

# Test user for sandbox - Required by Mercado Pago for subscriptions testing
MP_TEST_USER_ID=your-test-user-id

# Contiguity
CONTIGUITY_TOKEN=your-contiguity-token

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key

# Google Analytics & Tag Manager
# Get your GA4 Measurement ID from: https://analytics.google.com/ (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=XXX
# Get your GTM Container ID from: https://tagmanager.google.com/ (format: GTM-XXXXXXX)
# GTM is optional - only needed if you want to manage tags through Tag Manager
NEXT_PUBLIC_GTM_ID=XXX

# Brevo Webhook
BREVO_WEBHOOK_KEY=your-brevo-webhook-key

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# EventBridge Scheduler Configuration
EVENTBRIDGE_SCHEDULER_ROLE_ARN=arn:aws:iam::your-account-id:role/EventBridgeSchedulerRole

# =============================================================================
# Agentic System Configuration
# =============================================================================

# WebSocket URL for real-time AI agent communication
# Example: wss://api.example.com/ws
AGENTIC_WS_URL=wss://your-agent-backend.com/ws

# REST API URL for agentic system operations (session management, OAuth2, etc.)
# Example: https://api.example.com
AGENTIC_API_URL=https://your-agent-backend.com

# Default agent identifier for the AI agent system
# This ID determines which agent configuration to use from the backend
# Example: default-agent, apex-agent, etc.
AGENTIC_AGENT_ID=default-agent

# Application name used for session management and identification
# This name is used to group and retrieve conversation sessions
# Example: apex-app, my-app, etc.
AGENTIC_APP_NAME=apex-app
